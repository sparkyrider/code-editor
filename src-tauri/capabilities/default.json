{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "platforms": ["macOS", "windows", "linux"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "core:menu:default",
    "core:event:default",
    "window-state:default",
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-open",
    "allow-create-terminal",
    "allow-write-terminal",
    "allow-resize-terminal",
    "allow-kill-terminal",
    "allow-engine-status",
    "allow-engine-start",
    "allow-engine-stop",
    "allow-engine-restart",
    "allow-engine-gateway-config",
    "allow-local-read-tree",
    "allow-local-read-file",
    "allow-local-read-file-base64",
    "allow-local-write-file",
    "allow-local-git-info",
    "allow-local-git-diff",
    "allow-local-git-commit",
    "allow-local-git-branches",
    "allow-local-git-checkout",
    "allow-local-git-add",
    "allow-local-git-unstage",
    "allow-local-git-undo-commit",
    "allow-local-git-remote-url",
    "allow-local-git-push",
    "allow-local-git-log",
    "allow-local-git-has-upstream",
    "allow-local-git-ahead-behind",
    "allow-local-delete-path",
    "allow-local-git-discard",
    "allow-local-git-discard-staged",
    "allow-local-git-save",
    "allow-local-git-sync",
    "allow-local-git-clean-branches",
    "clipboard-manager:default",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-write-html",
    "clipboard-manager:allow-write-image",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-read-image",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "https://github.com/**" },
        { "url": "https://api.github.com/**" }
      ]
    },
    {
      "identifier": "http:allow-fetch-send",
      "allow": [
        { "url": "https://github.com/**" },
        { "url": "https://api.github.com/**" }
      ]
    }
  ]
}
