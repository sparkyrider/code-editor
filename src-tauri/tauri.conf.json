{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "KnotCode",
  "version": "1.2.0",
  "identifier": "ai.openknot.code-editor",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://127.0.0.1:3080",
    "beforeDevCommand": "pnpm frontend:dev",
    "beforeBuildCommand": "pnpm frontend:build"
  },
  "app": {
    "windows": [
      {
        "title": "KnotCode",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "appimage", "deb", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
